# ─── Stemmer fra Norddjurs — miljøvariabler ───
# Kopiér til .env og udfyld værdierne

# ─── Server ───
HOST=0.0.0.0
PORT=8321

# ─── Database ───
# SQLite (til lokal udvikling):
DATABASE_URL=sqlite:///./norddjurs.db
# SQL Server (til produktion på Windows-server):
# DATABASE_URL=mssql+pyodbc://brugernavn:adgangskode@server/database?driver=ODBC+Driver+18+for+SQL+Server

# ─── JWT ───
# VIGTIGT: Generér en unik, tilfældig nøgle (min. 32 tegn):
#   python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=SKIFT-MIG-generér-med-kommandoen-ovenfor
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=10080

# ─── CORS ───
# Kommaseparerede URLs til din frontend. Brug aldrig * i produktion.
# Eksempel: ALLOWED_ORIGINS=https://borger.norddjurs.dk,https://admin.norddjurs.dk
ALLOWED_ORIGINS=http://localhost:5173

# ─── Lydoptagelse / upload ───
UPLOAD_DIR=./uploads
# Maksimal filstørrelse for lydoptagelser i MB (standard: 10)
MAX_UPLOAD_SIZE_MB=10

# ─── Admin-konto (kun brugt ved første opstart/seeding) ───
# Sæt et kodeord her, eller lad feltet være tomt for at få et tilfældigt kodeord
# printet til terminalen ved første opstart (anbefalet).
ADMIN_INITIAL_PASSWORD=

# ─── Email-notifikationer (Microsoft 365 / SMTP) ───
# Udfyld for at aktivere notifikationer til admin ved flaggede svar og borgerspørgsmål
SMTP_HOST=smtp.office365.com
SMTP_PORT=587
SMTP_USER=noreply@norddjurs.dk
SMTP_PASSWORD=din-adgangskode-her
SMTP_FROM=noreply@norddjurs.dk
ADMIN_NOTIFY_EMAIL=din-email@norddjurs.dk

# ─── Transskriberings-model ───
# Anbefalet — dansk wav2vec2 (fin-tunet, god kvalitet):
WHISPER_MODEL=CoRal-project/roest-wav2vec2-315m-v2

# Alternativ — OpenAI Whisper medium (flersproget, pålidelig):
# WHISPER_MODEL=openai/whisper-medium

# ─── Ollama (lokal AI) ───
OLLAMA_URL=http://localhost:11434
OLLAMA_MODEL=qwen3:14b
