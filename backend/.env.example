# ─── Stemmer fra Norddjurs — miljøvariabler ───
# Kopiér til .env og udfyld værdierne

# ─── Server ───
HOST=0.0.0.0
PORT=8321

# ─── Database ───
# SQLite (til lokal udvikling):
DATABASE_URL=sqlite:///./norddjurs.db
# SQL Server (til produktion på Windows-server):
# DATABASE_URL=mssql+pyodbc://brugernavn:adgangskode@server/database?driver=ODBC+Driver+18+for+SQL+Server

# ─── JWT ───
SECRET_KEY=skift-mig-til-en-lang-tilfældig-streng-i-produktion
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=10080

# ─── Lydoptagelse / upload ───
UPLOAD_DIR=./uploads

# ─── Email-notifikationer (Microsoft 365 / SMTP) ───
# Udfyld for at aktivere notifikationer til admin ved flaggede svar og borgerspørgsmål
SMTP_HOST=smtp.office365.com
SMTP_PORT=587
SMTP_USER=noreply@norddjurs.dk
SMTP_PASSWORD=din-adgangskode-her
SMTP_FROM=noreply@norddjurs.dk
ADMIN_NOTIFY_EMAIL=din-email@norddjurs.dk

# ─── Transskriberings-model ───
# Vælg ét af følgende modeller (kommenter de andre ud):

# Anbefalet — dansk Whisper (fin-tunet, god kvalitet):
WHISPER_MODEL=CoRal-project/roest-wav2vec2-315m-v2

# Alternativ — CoRal Røst v2 (dansk wav2vec2):
# WHISPER_MODEL=CoRal-project/roest-wav2vec2-315m-v2

# Alternativ — OpenAI Whisper medium (flersproget, pålidelig):
# WHISPER_MODEL=openai/whisper-medium
